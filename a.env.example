.env.example# Kommo CRM Integration
# Obtén esta URL de: Kommo → Ajustes → Centro de Integraciones → Webhooks
# O de: https://scheduler.kommo.com/api/v1/external/hooks/crm
KOMMO_WEBHOOK_URL=https://scheduler.kommo.com/api/v1/external/hooks/crm/YOUR_TOKEN_HERE

# IDs de campos personalizados en Kommo (opcional - valores por defecto: 1 y 2)
KOMMO_EMAIL_FIELD_ID=1
KOMMO_PHONE_FIELD_ID=2

# TikTok Pixel ID
# Obtén esto de: TikTok Ads Manager → Events Manager → Tu Pixel
TIKTOK_PIXEL_ID=YOUR_TIKTOK_PIXEL_ID_HERE
